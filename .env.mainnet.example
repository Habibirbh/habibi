# ============================================================
# Habibi — Robinhood Chain MAINNET configuration (placeholders only)
# Copy to .env.mainnet (gitignored) and fill with REAL values.
# `npm run build` with APP_ENV=production refuses to compile until every
# required value is present, well-formed, non-placeholder, and non-localhost.
# ============================================================

APP_ENV=production
CHAIN_ID=4663

# --- Network (server-side RPC secret + public client RPC) -------
# RH_MAINNET_RPC_URL is used by deploy scripts / server; keep it out of the
# client bundle. NEXT_PUBLIC_ROBINHOOD_RPC_URL is the browser RPC and must NOT
# be the public fallback (https://rpc.mainnet.chain.robinhood.com).
RH_MAINNET_RPC_URL=
NEXT_PUBLIC_ROBINHOOD_RPC_URL=
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://robinhoodchain.blockscout.com
# Preview-mode opt-in: accept the shared public RPC (rate-limited) instead of a
# dedicated endpoint. Set to true only for a low-traffic preview launch.
NEXT_PUBLIC_ACCEPT_PUBLIC_RPC=

# --- Wallets ----------------------------------------------------
# OPTIONAL — injected/extension wallets work without it; only enables the
# WalletConnect mobile-QR path.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Deployed contracts (fill AFTER a verified mainnet deploy) --
# HabibiCampaigns is the live functional contract (conditional pre-acquisition
# escrow). The production build REQUIRES this address; it is what the property
# page, portfolio, and admin read/write.
NEXT_PUBLIC_CAMPAIGNS_CONTRACT_ADDRESS=
# Deprecated direct-treasury pools contract — NOT deployed on mainnet, left
# blank. Any UI referencing it stays fail-closed without it.
NEXT_PUBLIC_PROPERTY_CONTRACT_ADDRESS=

# --- Application ------------------------------------------------
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_COMPLIANCE_API_URL=
# Fundraising authorization switch. Leave UNSET/false to ship in preview mode
# (contract live, contributions disabled). Set to true ONLY once operator,
# custodian/escrow, and compliance authorization are genuinely in place.
NEXT_PUBLIC_OPERATOR_AUTHORIZATION_READY=

# --- Contract administration (public addresses) ----------------
HABIBI_TREASURY_ADDRESS=
HABIBI_ADMIN_MULTISIG=
HABIBI_PROPERTY_MANAGER=
HABIBI_PAUSER=
COMPLIANCE_SIGNER_ADDRESS=

# --- Property configuration -------------------------------------
# Real, legally-reviewed property parameters live in
# contracts/config/properties.json (NOT the *.example.json fixture).
PROPERTIES_CONFIG_PATH=config/properties.json

# --- Secrets (server/CI only — NEVER NEXT_PUBLIC_, never committed) ---
DEPLOYER_PRIVATE_KEY=
BLOCKSCOUT_API_KEY=

# --- Explicit mainnet broadcast gate ----------------------------
# Set ONLY when the DEPLOYMENT_GUIDE.md checklist is genuinely complete
# (independent audit, verified treasury/multisig/signer, REAL property data):
# MAINNET_DEPLOY_CONFIRMED=I_HAVE_COMPLETED_THE_MAINNET_CHECKLIST
