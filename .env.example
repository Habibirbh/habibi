# ============================================================
# Habibi — environment configuration (placeholders ONLY)
# Copy to .env.local and fill. NEVER commit .env files.
# NEVER prefix secrets with NEXT_PUBLIC_.
# Production deployment must reject placeholder values.
# ============================================================

# --- Application -------------------------------------------------
# "development" targets the local anvil chain (31337).
# "production" targets Robinhood Chain (4663) and hard-disables
# purchases until the compliance API is configured.
NEXT_PUBLIC_APP_ENV=development

# --- Robinhood Chain --------------------------------------------
NEXT_PUBLIC_ROBINHOOD_CHAIN_ID=4663
# Production RPC (Alchemy/QuickNode/etc). The public endpoint
# https://rpc.mainnet.chain.robinhood.com is a FALLBACK only.
NEXT_PUBLIC_ROBINHOOD_RPC_URL=
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://robinhoodchain.blockscout.com

# --- Wallets ----------------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Contracts (verified deployments only) ----------------------
NEXT_PUBLIC_PROPERTY_CONTRACT_ADDRESS=

# --- Compliance -------------------------------------------------
# Purchase submission on mainnet is disabled until this is set.
NEXT_PUBLIC_COMPLIANCE_API_URL=
COMPLIANCE_SIGNER_ADDRESS=

# --- Deployment (server-side / CI only — SECRETS) ---------------
# Deployer key for forge scripts. Never the treasury key.
DEPLOYER_PRIVATE_KEY=
# Checksummed treasury address (multisig / institutional custody).
HABIBI_TREASURY_ADDRESS=
# Governance multisig that receives all roles post-deployment.
HABIBI_ADMIN_MULTISIG=
# Explicit mainnet gate — set ONLY after completing the checklist
# in DEPLOYMENT_GUIDE.md (audit, verified addresses, approvals):
# MAINNET_DEPLOY_CONFIRMED=I_HAVE_COMPLETED_THE_MAINNET_CHECKLIST

# Path to the reviewed production property config (contracts/ relative).
# The example file fails validation by design.
PROPERTIES_CONFIG_PATH=config/properties.json

# --- Optional services ------------------------------------------
BLOCKSCOUT_API_KEY=
ALCHEMY_WEBHOOK_SIGNING_KEY=
DATABASE_URL=

# --- Habibi Intelligence -----------------------------------------
AI_PROVIDER=fallback-deterministic
AI_MODEL=gemini-3.5-flash
AI_API_KEY=
AI_EMBEDDING_PROVIDER=
AI_EMBEDDING_MODEL=
AI_EMBEDDING_API_KEY=
AI_MAX_OUTPUT_TOKENS=1024
AI_TEMPERATURE=0.2
AI_REQUEST_TIMEOUT_MS=10000
AI_ANONYMOUS_DAILY_LIMIT=10
AI_WALLET_DAILY_LIMIT=50
AI_ADMIN_DAILY_LIMIT=200

NEXT_PUBLIC_INTELLIGENCE_ENABLED=true
NEXT_PUBLIC_INTELLIGENCE_MAX_PROPERTIES_COMPARE=3
NEXT_PUBLIC_INTELLIGENCE_PORTFOLIO_PERSONALIZATION=true
