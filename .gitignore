# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore all real env files (incl. .env, .env.local,
# .env.production, .env.mainnet) but keep the placeholder templates committable.
.env*
!.env.example
!.env.mainnet.example

# demo/local treasury ledger and deployment secrets
.data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# demo treasury ledger (server state)
.data/

# local tooling / editor state (may contain machine-local paths or test keys)
.claude/
.DS_Store

# Foundry build artifacts & installed libs (restore with: forge install)
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/lib/

# Third-party source material dropped in for reference — NOT licensed for
# publication (e.g. developer marketing renders). Never commit/publish.
Palmiera 2/
